<Window x:Class="CurrencyConverter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Конвертер валют" Height="300" Width="400">
    <Grid Margin="10,10,10,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Конвертер валют" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Из валюты:" VerticalAlignment="Center"/>
        <ComboBox x:Name="cmbFrom" Grid.Row="1" Grid.Column="1" Margin="0,5"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="В валюту:" VerticalAlignment="Center"/>
        <ComboBox x:Name="cmbTo" Grid.Row="2" Grid.Column="1" Margin="0,5"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Сумма:" VerticalAlignment="Center"/>
        <TextBox x:Name="txtAmount" Grid.Row="3" Grid.Column="1" Margin="0,5" Text="1"/>

        <Button x:Name="btnConvert" Grid.Row="4" Grid.ColumnSpan="2" Content="Конвертировать" Click="BtnConvert_Click" Margin="0,10" Height="30"/>
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Результат:" VerticalAlignment="Center" Margin="10,0,0,0"/>
        <TextBox x:Name="txtResult" Grid.Row="4" Grid.Column="1" Margin="0,10,0,10" IsReadOnly="True" Background="LightGray"/>
    </Grid>
</Window>